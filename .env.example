# ============================================================
#  .env — Biến môi trường cho FinMate OCR Backend
#  ⚠️  KHÔNG commit file .env thật lên Git!
# ============================================================

# Cổng server (mặc định 3001)
PORT=3001

# Đường dẫn tới file credentials JSON của Google Cloud Service Account
# Tải về từ: Google Cloud Console → IAM → Service Accounts → Tạo key JSON
GOOGLE_APPLICATION_CREDENTIALS=./finmate-google-credentials.json
